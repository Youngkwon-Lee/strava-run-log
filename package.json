{
  "name": "strava-run-log",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "gate:pghd:release": "npm test && npm run smoke:dashboard:viewport && npm run smoke:pghd && npm run check:pghd:smoke-cleanup && npm run check:pghd:release-readiness",
    "gate:pghd:physio-release": "npm run gate:pghd:release && npm run check:pghd:physio-handoff -- --static-only",
    "gate:pghd:strict-staging": "npm run smoke:pghd:strict-full && npm run check:pghd:physio-handoff -- --static-only && npm run check:pghd:smoke-cleanup",
    "gate:pghd:decision": "node scripts/run_pghd_release_decision.mjs",
    "smoke:dashboard:viewport": "node scripts/smoke_dashboard_viewport.mjs",
    "smoke:pghd": "node scripts/smoke_pghd_e2e.mjs",
    "smoke:pghd:strict-org-client": "PGHD_SMOKE_BOOTSTRAP_ORG_CLIENT=1 PGHD_SMOKE_REQUIRE_ORG_CLIENT_CONTEXT=1 node scripts/smoke_pghd_e2e.mjs",
    "smoke:pghd:strict-full": "PGHD_SMOKE_BOOTSTRAP_ORG_CLIENT=1 PGHD_SMOKE_REQUIRE_ORG_CLIENT_CONTEXT=1 PGHD_SMOKE_MATERIALIZE_STATE=1 node scripts/smoke_pghd_e2e.mjs",
    "apply:pghd:state-migration": "node scripts/apply_pghd_state_migration.mjs",
    "apply:pghd:state-sql-direct": "node scripts/apply_pghd_state_sql_direct.mjs",
    "apply:pghd:migration-reconciliation": "node scripts/apply_pghd_migration_reconciliation.mjs",
    "check:pghd:physio-handoff": "node scripts/check_pghd_physio_handoff_readiness.mjs",
    "check:pghd:smoke-cleanup": "node scripts/check_pghd_smoke_cleanup.mjs",
    "report:pghd:release-decision": "node scripts/report_pghd_release_decision.mjs",
    "check:pghd:migration-history": "node scripts/check_pghd_migration_history.mjs",
    "plan:pghd:migration-reconciliation": "node scripts/plan_pghd_migration_reconciliation.mjs",
    "check:pghd:release-readiness": "node scripts/check_pghd_release_readiness.mjs",
    "check:pghd:status": "node scripts/check_pghd_status.mjs",
    "check:pghd:state-functional": "node scripts/check_pghd_state_functional.mjs",
    "check:pghd:state-schema": "node scripts/check_pghd_state_schema.mjs",
    "smoke:pghd:state": "node scripts/smoke_pghd_state_materialization.mjs",
    "smoke:pghd:state:db": "node scripts/smoke_pghd_state_db.mjs",
    "seed:pghd:demo-client": "node scripts/seed_pghd_demo_client.mjs",
    "check:pghd:demo-client": "node scripts/seed_pghd_demo_client.mjs --check",
    "smoke:pghd:db": "supabase db query --linked --file scripts/smoke_pghd_db.sql -o table"
  }
}
